# 複製此檔為 .env 並填入你自己的值（.env 不會被提交到 git）
# 到 Google Cloud Console 重新產生一組金鑰後填入：

GOOGLE_CLIENT_ID=你的_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=你的_新_client_secret

# Flask session 加密金鑰，請填一段隨機字串
FLASK_SECRET=請改成一段隨機長字串

# ── 選填：社群登入（沒填就不會啟用，該按鈕點了會提示尚未設定）──
# Facebook：到 https://developers.facebook.com 建立應用程式後填入
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LINE：到 https://developers.line.biz 建立 LINE Login channel 後填入
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# ── 選填：Google 地圖底圖 + 導航路線 ──
# 沒填 → 地圖自動用 Leaflet + OpenStreetMap（功能正常，只是底圖不是 Google）。
# 有填 → 消費地圖 / 行程規劃改用 Google 地圖 + Directions 真實路線。
# 申請：Google Cloud Console → 啟用「Maps JavaScript API」和「Directions API」→ 建立 API 金鑰。
# 安全：務必到金鑰設定裡「應用程式限制」選 HTTP 參照網址，加入 http://localhost:5001/*
#       與正式網域，避免金鑰外流被盜刷。
GOOGLE_MAPS_API_KEY=
